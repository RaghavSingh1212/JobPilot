{
  "manifest_version": 3,
  "name": "Job Application Copilot",
  "description": "Score job fit, reject poor matches, and safely autofill applications without submitting.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "scripting", "alarms", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Job Copilot",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/shared/defaults.js", "src/shared/matcher.js", "src/shared/applicationAnswers.js", "src/content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
